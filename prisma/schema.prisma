generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  name                 String?
  passwordHash         String
  balance              Float                 @default(0)
  role                 String                @default("USER")
  status               String                @default("ACTIVE")
  createdAt            DateTime              @default(now())
  // Affiliate fields
  affiliateCode        String?               @unique
  referredById         String?
  // Tier subscription
  tier                 String                @default("FREE") // FREE | BASIC | ADV | ULTRA
  tierSource           String                @default("AUTO") // AUTO | PAID
  tierExpiresAt        DateTime?
  apiKeys              ApiKey[]
  topups               TopupRequest[]
  usage                UsageLog[]
  transactions         Transaction[]
  subscriptions        Subscription[]
  referrals            User[]                @relation("UserReferrals")
  referredBy           User?                 @relation("UserReferrals", fields: [referredById], references: [id])
  commissions          AffiliateCommission[] @relation("AffiliateEarner")
  generatedCommissions AffiliateCommission[] @relation("ReferralSource")
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  plan      String // BASIC | ADV
  period    String // MONTH | HALF_YEAR | YEAR
  amount    Float // VND đã trừ vào balance lúc mua
  startedAt DateTime @default(now())
  expiresAt DateTime
  status    String   @default("ACTIVE") // ACTIVE | EXPIRED | CANCELLED
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model ApiKey {
  id           String     @id @default(cuid())
  userId       String
  name         String
  keyHash      String     @unique
  prefix       String
  suffix       String
  encryptedKey String? // AES-256-GCM ciphertext của full key (nullable cho key cũ trước khi migrate)
  enabled      Boolean    @default(true)
  lastUsedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  usage        UsageLog[]
  models       ApiKeyModel[]
}

// Mỗi API key user tạo phải subscribe vào N model admin để được gọi.
// Gateway check ApiKeyModel.where({ apiKeyId, modelId, enabled: true }) trước khi forward.
model ApiKeyModel {
  id        String   @id @default(cuid())
  apiKeyId  String
  modelId   String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  apiKey    ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  model     Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, modelId])
  @@index([apiKeyId])
  @@index([modelId])
}

model Model {
  id            String    @id @default(cuid())
  slug          String    @unique
  displayName   String
  provider      String // branding string ("openai/anthropic/...") cho logo display
  category      String    @default("text") // text | embedding | image | video | tts
  priceUnit     String    @default("1M tokens") // "1M tokens" | "1 ảnh" | "1 giây" | "1M ký tự"
  inputPrice    Float
  outputPrice   Float
  contextLength Int
  description   String?
  active        Boolean   @default(true)
  freeDiscount  Float     @default(0)
  basicDiscount Float     @default(0)
  advDiscount   Float     @default(0)
  speedTps      Float     @default(0)
  latencyMs     Float     @default(0)
  uptimeStatus  String    @default("good")
  createdAt     DateTime  @default(now())
  // === Upstream config (1 model = 1 key) ===
  apiType       String    @default("OPENAI_COMPATIBLE") // OPENAI | ANTHROPIC | GEMINI | OLLAMA | OPENAI_COMPATIBLE
  apiBaseUrl    String? // null → endpoint mặc định theo apiType
  apiKeyEnc     String? // AES-256-GCM ciphertext của API key; null → fallback env
  apiKeyPrefix  String? // 8 ký tự đầu để show UI
  upstreamSlug  String? // tên model thật ở upstream; null → dùng `slug`
  // === Stats theo key (rolling) ===
  totalRequests Int       @default(0)
  totalErrors   Int       @default(0)
  lastUsedAt    DateTime?
  lastErrorAt   DateTime?
  // === Deprecated: provider relation (giữ nullable cho backward-compat) ===
  providerId    String?
  providerRef   Provider? @relation(fields: [providerId], references: [id])
  // === Multi-modality pricing ===
  // modality: TEXT | IMAGE | VIDEO | AUDIO_TTS | AUDIO_STT | EMBEDDING
  // pricingData JSON shape phụ thuộc modality:
  //   - TEXT/EMBEDDING: null (dùng inputPrice/outputPrice cũ)
  //   - IMAGE: { matrix: [{ size, quality, price }] } (VND/ảnh)
  //   - VIDEO: { matrix: [{ resolution, duration, price }] } (VND/video)
  //   - AUDIO_TTS: { charRate, voices: [{ id, name, gender?, preview? }] } (VND/1M chars)
  //   - AUDIO_STT: { minuteRate, languages: string[] } (VND/phút)
  modality      String    @default("TEXT")
  pricingData   Json?
  // Reverse relation cho ApiKeyModel
  apiKeySubs    ApiKeyModel[]

  @@index([providerId])
}

// Upstream provider — admin tạo qua /admin/providers
model Provider {
  id          String        @id @default(cuid())
  name        String // "My OpenAI Provider"
  description String?
  type        String // OPENAI | ANTHROPIC | GEMINI | OLLAMA | OPENAI_COMPATIBLE
  baseUrl     String? // null cho OPENAI/ANTHROPIC/GEMINI dùng default endpoint
  enabled     Boolean       @default(true)
  routing     String        @default("ROUND_ROBIN") // ROUND_ROBIN | FAILOVER | RANDOM | LEAST_USED
  rrCursor    Int           @default(0) // pointer cho round-robin
  createdAt   DateTime      @default(now())
  keys        ProviderKey[]
  models      Model[]
}

model ProviderKey {
  id            String    @id @default(cuid())
  providerId    String
  encryptedKey  String // AES-256-GCM ciphertext (reuse encryptKey() từ key-cipher.ts)
  prefix        String // 8 ký tự đầu hiển thị UI ("sk-abc1...")
  label         String? // "Key 1", "Trial"…
  enabled       Boolean   @default(true)
  lastUsedAt    DateTime?
  lastErrorAt   DateTime?
  errorCount    Int       @default(0) // rolling — reset khi success
  totalRequests Int       @default(0)
  totalErrors   Int       @default(0)
  createdAt     DateTime  @default(now())
  provider      Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, enabled])
}

model TopupRequest {
  id             String           @id @default(cuid())
  userId         String
  amount         Float
  method         String
  reference      String?          @unique
  note           String?
  status         String           @default("PENDING")
  processedBy    String?
  processedAt    DateTime?
  autoApproved   Boolean          @default(false)
  receivedAmount Float?
  promoCode      String?          // mã user nhập lúc tạo (UPPERCASE), null nếu không có
  promoBonus     Float?           // bonus tính từ promo code (lưu lại để approveTopup khỏi tính lại)
  createdAt      DateTime         @default(now())
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankTx         BankTransaction?
  promoRedemption PromoRedemption?
}

// Log toàn bộ giao dịch ngân hàng nhận từ webhook (Sepay/Casso).
// Idempotent qua gatewayTxId; match với TopupRequest qua reference parse từ content.
model BankTransaction {
  id              String        @id @default(cuid())
  gatewayTxId     String        @unique // id từ provider (Sepay id)
  gatewayName     String        // "Vietinbank" / "Sepay" v.v.
  accountNumber   String?
  amount          Float
  content         String        @db.Text
  transferType    String        // "in" | "out"
  reference       String?       // QT-xxxxx extracted từ content
  matchedTopupId  String?       @unique
  matchedTopup    TopupRequest? @relation(fields: [matchedTopupId], references: [id])
  transactionDate DateTime
  rawPayload      Json?
  createdAt       DateTime      @default(now())

  @@index([reference])
  @@index([transactionDate])
}

model Transaction {
  id           String   @id @default(cuid())
  userId       String
  type         String
  amount       Float
  balanceAfter Float
  description  String
  refId        String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageLog {
  id           String   @id @default(cuid())
  userId       String
  apiKeyId     String
  modelSlug    String
  inputTokens  Int
  outputTokens Int
  cost         Float
  status       Int
  ip           String?
  // === Multi-modality snapshot ===
  modality     String?  // TEXT | IMAGE | VIDEO | AUDIO_TTS | AUDIO_STT | EMBEDDING — null = TEXT legacy
  unitsMeta    Json?    // { size, quality, count } | { resolution, duration } | { chars, voice } | { seconds, language }
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey       ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
}

model AffiliateCommission {
  id          String   @id @default(cuid())
  earnerId    String // ai nhận hoa hồng
  referredId  String // user nào sinh ra giao dịch
  topupId     String? // nguồn topup
  amount      Float // số tiền hoa hồng (VND)
  rate        Float // % áp dụng
  description String
  createdAt   DateTime @default(now())
  earner      User     @relation("AffiliateEarner", fields: [earnerId], references: [id], onDelete: Cascade)
  referred    User     @relation("ReferralSource", fields: [referredId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String // markdown
  coverEmoji  String   @default("📝")
  tag         String   @default("Tin tức")
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
}

model ChangelogEntry {
  id         String   @id @default(cuid())
  version    String
  title      String
  content    String // markdown
  kind       String   @default("feature") // feature | fix | improvement
  releasedAt DateTime @default(now())
  createdAt  DateTime @default(now())
}

// ─── Mã ưu đãi nạp tiền ──────────────────────────────────────────────────
// Admin tạo mã. User nhập tại /topup. Khi topup được approve, bonus tính theo
// percent (vd 10% × số tiền nạp) hoặc số tiền cố định, cộng vào balance cùng
// lúc với bonus mệnh giá có sẵn.
model PromoCode {
  id              String            @id @default(cuid())
  code            String            @unique // UPPERCASE, vd "APIONDINH"
  description     String?
  // Loại bonus: PERCENT (bonusPercent × amount) hoặc FIXED (bonusAmount cố định)
  bonusType       String            @default("PERCENT") // PERCENT | FIXED
  bonusPercent    Float             @default(0)         // 0-100, dùng khi PERCENT
  bonusAmount     Float             @default(0)         // VND, dùng khi FIXED
  minAmount       Float             @default(0)         // số tiền nạp tối thiểu để áp dụng (VND)
  maxBonus        Float?            // cap bonus (vd 10% × 100M = 10M nhưng cap 5M)
  // Điều kiện sử dụng
  firstUseOnly    Boolean           @default(false)     // chỉ áp dụng cho user CHƯA TỪNG DÙNG mã này
  // Lifecycle
  enabled         Boolean           @default(true)
  startsAt        DateTime?         // null = áp dụng ngay
  expiresAt       DateTime?         // null = không hết hạn
  maxUses         Int?              // null = không giới hạn tổng số lượt dùng
  usedCount       Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  redemptions     PromoRedemption[]

  @@index([enabled, expiresAt])
}

// Ghi nhận mỗi lần user áp dụng mã thành công (topup được duyệt).
// 1 topup = 1 redemption (unique trên topupId). Dùng để check firstUseOnly + lịch sử.
model PromoRedemption {
  id          String       @id @default(cuid())
  promoCodeId String
  userId      String
  topupId     String       @unique
  amount      Float        // số tiền nạp tại thời điểm áp
  bonus       Float        // bonus đã cộng cho user
  createdAt   DateTime     @default(now())
  promoCode   PromoCode    @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  topup       TopupRequest @relation(fields: [topupId], references: [id], onDelete: Cascade)

  @@index([promoCodeId, userId])
  @@index([userId])
}
